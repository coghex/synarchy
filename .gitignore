config/shell_history.txt
# Local runtime/user config state written by the settings UI's Save
# actions. Versioned defaults/templates (config/*_default.yaml,
# config/pathing.yaml, config/world_gen_default.yaml) are NOT covered by
# these and stay tracked.
#
# config/video.yaml / config/keybinds.yaml / config/notifications.yaml
# are the pre-#661 paths — nothing writes to them any more (#786 moved
# Save actions to the *.local.yaml paths below), but they stay listed
# here in case one ever survives on disk from an old checkout: should
# it, Engine.Core.Init.migrateLegacyConfig reads it once (if no
# *.local.yaml exists yet) to seed the player's local file rather than
# silently ignoring it.
config/video.yaml
config/keybinds.yaml
config/notifications.yaml
config/video.local.yaml
config/keybinds.local.yaml
config/notifications.local.yaml
saves/
.claude/
src/World/Hydrology/DESIGN.md
soil
stone

# Playtest harness session traces (#647) — per-run output, never committed
tools/playtest/sessions/
