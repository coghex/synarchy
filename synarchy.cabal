cabal-version:      3.16
name:               synarchy
version:            0.1.0.0
synopsis:           Vulkan-based colony-simulation game with procedural worlds
description:
    Synarchy is a colony-simulation game and engine written in Haskell:
    a bindless Vulkan renderer with GLFW windowing, a multi-threaded
    engine core (render, input, world, unit, and Lua scripting threads
    communicating over STM), procedural world generation with geological,
    hydrological, and climate simulation, and game logic driven from an
    embedded Lua scripting API.
    .
    This package is developed and built from its source repository; it is
    not published to Hackage. See README.md for build and test
    instructions and CLAUDE.md for the full development workflow.
homepage:           https://github.com/coghex/synarchy
bug-reports:        https://github.com/coghex/synarchy/issues
license:            MIT
license-file:       LICENSE
author:             coghex
maintainer:         vincecoghlan@gmail.com
category:           Game
build-type:         Custom
tested-with:        GHC ==9.12.2
extra-doc-files:    CHANGELOG.md
                    README.md
                    CLAUDE.md
-- The sdist is the source tree: besides the headers for the c-sources
-- below (which sdist does not pick up from include-dirs on its own),
-- ship the runtime/test resources the engine and test suites load from
-- relative paths at run time — game-data YAML, image/font assets, the
-- Lua game scripts, and the versioned config templates. The config
-- entries are enumerated (not globbed) on purpose: config/ also holds
-- gitignored local runtime state (keybinds.yaml, video.yaml,
-- notifications.yaml, #638) that a glob would leak into the tarball.
extra-source-files: cbits/*.h
                    data/**/*.yaml
                    assets/**/*.png
                    assets/**/*.ttf
                    scripts/**/*.lua
                    config/keybinds_default.yaml
                    config/pathing.yaml
                    config/video_default.yaml
                    config/world_gen_default.yaml

source-repository head
    type:     git
    location: https://github.com/coghex/synarchy.git

-- Setup.hs only clears the macOS quarantine xattr from freshly built
-- artifacts after each build; everything else is stock Cabal.
custom-setup
    setup-depends: base >=4.17 && <5
                 , Cabal >=3.16 && <3.17
                 , directory >=1.3 && <1.4
                 , process >=1.6 && <1.7

flag dev
    description: Development profile - Vulkan validation layers, ENGINE_DEBUG
                 plumbing, and (macOS) address sanitizer for the graphical
                 test suite. Give it its own build dir; see CLAUDE.md.
    default: False
    manual: True

flag profile
    description: Cost-centre profiling (-fprof-late on top of the prod -O2);
                 see CLAUDE.md for the full recipe.
    default: False
    manual: True

-- Shared warning policy (#435): prod is the default for all routine
-- work, so it must carry the full warning set. Keep this the single
-- source of truth — don't re-add warning flags inside per-component
-- stanzas or the build-policy conditionals below.
common warnings
    ghc-options: -Wall
                 -Wcompat
                 -Wincomplete-record-updates
                 -Wincomplete-uni-patterns
                 -Wincomplete-patterns
                 -Wno-ambiguous-fields
                 -- name-shadowing: ~70 pre-existing shadows; bulk renames
                 -- risk the wrong-variable bugs the warning guards against.
                 -- Revisit incrementally, not as a sweep (#435).
                 -Wno-name-shadowing
                 -- type-defaults: all literal defaulting in log/format
                 -- code; annotating adds noise without catching bugs.
                 -Wno-type-defaults

common lang
    default-language: GHC2024
    default-extensions: DefaultSignatures
                      , DuplicateRecordFields
                      , MagicHash
                      , NoMonomorphismRestriction
                      , NoImplicitPrelude
                      , NumDecimals
                      , OverloadedStrings
                      , PatternSynonyms
                      , QuantifiedConstraints
                      , RecordWildCards
                      , TypeFamilyDependencies
                      , UnicodeSyntax
                      , ViewPatterns
                      , QuasiQuotes

-- Shared dev/prod/profile option policy (#635). Before this existed as
-- four hand-copied conditional blocks that had silently drifted apart;
-- any change to profile options belongs HERE, not in a component stanza.
-- Per-component extras are limited to RTS options (executables/tests)
-- and the graphical suite's macOS address sanitizer.
common build-policy
    ghc-options: -threaded
    if flag(dev)
      cpp-options: -DDEVELOPMENT
      -- No explicit -O here: Cabal's default -O1 already applies, and
      -- `cabal check` rejects spelling it out.
      ghc-options: -haddock
      if os(darwin)
        cpp-options: -DDARWIN
        ghc-options: -optP-Wno-nonportable-include-path
                     -fno-full-laziness
                     -fno-cse
                     -fPIC
                     -optl-Wl,-dead_strip
                     -optl-Wl,-bind_at_load
    else
      -- `cabal check` warns that -O2 is "rarely needed"; here it is
      -- deliberate and load-bearing: the prod profile is documented as
      -- -O2 -optc-O3 (CLAUDE.md) and worldgen/render throughput depends
      -- on it. Accepted warning, not an oversight.
      ghc-options: -O2
                   -optc-O3
                   -fexcess-precision
                   -feager-blackholing
      if os(darwin)
        cpp-options: -DDARWIN
        ghc-options: -optP-Wno-nonportable-include-path
    if flag(profile)
      ghc-options: -fprof-late

-- Dependency bounds policy: only `base` (and the custom-setup deps)
-- carry explicit upper bounds — that is the one `cabal check` treats as
-- an error. This package is built from this repository against a pinned
-- toolchain (see tested-with), not released to Hackage, so speculative
-- PVP upper bounds on the ~35 direct dependencies would only cause
-- solver churn; `cabal check`'s missing-upper-bounds warning on the
-- rest is accepted deliberately (#635).

