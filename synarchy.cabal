executable synarchy
    import: warnings, lang, build-policy
    -- .hs or .lhs file containing the Main module.
    main-is: Main.hs
    other-modules: App.Cli
                 , App.Exception
                 , App.Graphical
                 , App.Headless
                 , App.Dump
                 , App.Preview
                 , App.ResourceRoot
    default-extensions: FlexibleInstances
    other-extensions: Strict
                    , StrictData
                    , TemplateHaskell
    -- Other library packages from which modules are imported.
    build-depends: base >=4.20 && <5
                 , base-unicode-symbols
                 , bytestring
                 , containers
